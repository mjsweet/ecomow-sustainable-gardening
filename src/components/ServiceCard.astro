---
export interface Props {
  title: string;
  description: string;
  href: string;
  price?: string;
  icon?: string;
}
const { title, description, href, price } = Astro.props;
---

<div class="bg-white rounded-xl p-6 shadow-md border border-secondary-100 hover:shadow-lg transition-shadow">
  <h3 class="text-lg font-semibold text-secondary-800 mb-2">{title}</h3>
  <p class="text-secondary-600 text-sm mb-4">{description}</p>
  {price && (
    <p class="text-primary-700 font-semibold text-sm mb-4">{price}</p>
  )}
  <div class="flex gap-3">
    <a href="/quote" class="text-sm font-medium text-white bg-primary-700 px-4 py-2 rounded-full hover:bg-primary-800 transition-colors">
      Get Quote
    </a>
    <a href={href} class="text-sm font-medium text-primary-700 hover:text-primary-800 py-2 transition-colors">
      Learn more
    </a>
  </div>
</div>
