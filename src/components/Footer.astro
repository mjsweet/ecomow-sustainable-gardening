          <li><a href="/services/garden-maintenance" class="text-secondary-300 hover:text-primary-400">Garden Maintenance</a></li>
          <li><a href="/services/hedging-services" class="text-secondary-300 hover:text-primary-400">Hedging Services</a></li>
          <li><a href="/services/acreage-services" class="text-secondary-300 hover:text-primary-400">Acreage Services</a></li>
          <li><a href="/services/pruning-services" class="text-secondary-300 hover:text-primary-400">Pruning Services</a></li>
