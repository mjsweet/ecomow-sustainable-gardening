          <li><a href="/learn/garden-techniques" class="text-secondary-300 hover:text-primary-400">Garden Techniques</a></li>
          <li><a href="/learn/equipment" class="text-secondary-300 hover:text-primary-400">Equipment &amp; Technology</a></li>
          <li><a href="/learn/impact-community" class="text-secondary-300 hover:text-primary-400">Environmental Impact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-4">Service Areas</h4>
        <p class="text-secondary-300 text-sm mb-3">Based in Loganlea</p>
        <ul class="space-y-1 text-sm">
          <li><a href="/service-areas/loganlea" class="text-secondary-300 hover:text-primary-400">Loganlea (Homebase)</a></li>
          <li><a href="/service-areas/marsden" class="text-secondary-300 hover:text-primary-400">Marsden</a></li>
          <li><a href="/service-areas/crestmead" class="text-secondary-300 hover:text-primary-400">Crestmead</a></li>
          <li><a href="/service-areas/logan-reserve" class="text-secondary-300 hover:text-primary-400">Logan Reserve</a></li>
          <li><a href="/service-areas/chambers-flat" class="text-secondary-300 hover:text-primary-400">Chambers Flat</a></li>
