---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="404: Page Not Found | EcoMow Sustainable Gardening"
  description="The page you're looking for could not be found. Return to the EcoMow homepage or contact us for assistance."
>
  <section class="py-24 bg-white">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h1 class="text-6xl font-bold text-primary-600 mb-4">404</h1>
      <h2 class="text-2xl font-semibold text-secondary-800 mb-4">Page Not Found</h2>
      <p class="text-secondary-500 mb-8">
        The page you're looking for doesn't exist or has been moved. Let's get you back on track.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-block bg-primary-800 text-white font-semibold px-8 py-3 rounded-full hover:bg-primary-900 transition-colors">
          Go to Homepage
        </a>
        <a href="/contact" class="inline-block border-2 border-primary-800 text-primary-800 font-semibold px-8 py-3 rounded-full hover:bg-primary-50 transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
