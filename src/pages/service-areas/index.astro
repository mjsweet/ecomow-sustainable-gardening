---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";

const zones = [
  {
    name: "Regular Zone",
    description: "Within 12 min drive &mdash; Weekly and fortnightly maintenance available",
    suburbs: ["Loganlea", "Meadowbrook", "Waterford West", "Kingston", "Marsden", "Bethania", "Berrinba", "Logan Reserve", "Waterford", "Crestmead", "Logan Central", "Slacks Creek", "Edens Landing", "Tanah Merah", "Drewvale", "Daisy Hill", "Loganholme", "Karawatha", "Woodridge", "Holmview", "Browns Plains", "Buccan", "Parkinson", "Bahrs Scrub", "Beenleigh", "Chambers Flat"],
  },
];

const weeklySchedule: Record<string, string[]> = {
  "Monday": ["Loganlea (Homebase)"],
  "Tuesday": ["Marsden", "Crestmead", "Logan Reserve", "Chambers Flat", "Berrinba", "Drewvale", "Browns Plains", "Parkinson", "Heritage Park"],
  "Wednesday": ["Kingston", "Logan Central", "Slacks Creek", "Woodridge", "Underwood"],
  "Thursday": ["Waterford West", "Bethania", "Edens Landing", "Holmview", "Beenleigh"],
  "Friday": ["Waterford", "Bahrs Scrub", "Buccan", "Logan Village", "Yarrabilba"],
};
---

<BaseLayout
  title="Service Areas | EcoMow Sustainable Gardening Coverage Areas"
  description="Discover EcoMow's service areas across Logan City, Brisbane south, and Gold Coast north. Different service levels available based on location from our Loganlea homebase."
  keywords="service areas, Logan City garden services, Brisbane south gardening, Loganlea garden maintenance, weekly fortnightly lawn care coverage"
  canonical="https://www.ecomow.com.au/service-areas"
>
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-center mb-4 text-secondary-900">Our Service Areas</h1>
      <p class="text-center text-secondary-500 mb-12 text-lg max-w-2xl mx-auto">
        Based in Loganlea, we provide different service levels across Logan City and surrounding areas. Our coverage is organised into zones based on drive time from our homebase.
      </p>

      <!-- Zones -->
      <div class="space-y-8 mb-16">
        {zones.map((zone) => (
          <div class="bg-secondary-50 rounded-xl p-8">
            <h2 class="text-2xl font-bold mb-2 text-secondary-800">{zone.name}</h2>
            <p class="text-secondary-500 mb-6" set:html={zone.description}></p>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
              {zone.suburbs.map((s) => {
                const slug = s.toLowerCase().replace(/\s+/g, "-");
                return (
                  <a href={`/service-areas/${slug}`} class="bg-white border border-secondary-200 rounded-lg px-4 py-3 text-sm text-secondary-700 hover:border-primary-400 hover:text-primary-700 transition-colors text-center">
                    {s}
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </div>

      <!-- Weekly Schedule -->
      <h2 class="text-3xl font-bold text-center mb-8 text-secondary-900">Weekly Service Schedule</h2>
      <div class="grid md:grid-cols-5 gap-4">
        {Object.entries(weeklySchedule).map(([day, suburbs]) => (
          <div class="bg-white border border-secondary-200 rounded-xl p-4">
            <h3 class="font-semibold text-primary-700 mb-3">{day}</h3>
            <ul class="space-y-1 text-sm text-secondary-600">
              {suburbs.map((s) => <li>{s}</li>)}
            </ul>
          </div>
        ))}
      </div>

      <div class="mt-8 bg-primary-50 rounded-xl p-6 text-center">
        <p class="text-secondary-600 mb-4">Outside regular service zones? We also offer extended and project zone services &mdash; contact us to discuss your needs.</p>
        <a href="/quote" class="inline-block bg-primary-800 text-white font-semibold px-6 py-3 rounded-full hover:bg-primary-900 transition-colors">
          Check Availability in Your Area
        </a>
      </div>
    </div>
  </section>
  <CTA />
</BaseLayout>
